# ─────────────────────────────────────────────────────────────────────────────
# CIRO – Environment Variables Template
# Copy to `.env` (in the repo root or /backend) and fill in the values you have.
# Every variable below is OPTIONAL — the system has fallbacks for each.
# ─────────────────────────────────────────────────────────────────────────────

# ── Reasoning Agent (LLM) ────────────────────────────────────────────────────
# Primary: Groq (free, fast, llama-3.3-70b-versatile).
# Without this, the Reasoning Agent falls back to the cached analysis library.
GROQ_API_KEY=

# Optional alternate LLM provider — Google Gemini via Vertex AI.
# If both Groq and Gemini are set, Groq is used (faster, free).
GEMINI_API_KEY=AQ.Ab8RN6L8PNBOXVKXGcrbSaOGX6YJbIO8CHvEPBlFfYM6yG8JDA
GOOGLE_CLOUD_PROJECT=ciro-496512
GOOGLE_CLOUD_LOCATION=us-central1
GEMINI_MODEL=gemini-2.5-flash

# ── Google Maps ──────────────────────────────────────────────────────────────
# Only needed if you want the Static Maps endpoint to render real tiles.
# The web dashboard uses free Leaflet/OSM by default — no key required.
GOOGLE_MAPS_API_KEY=

# ── Google Antigravity / ADK ────────────────────────────────────────────────
# Project ID used by the ADK pipeline (backend/agents/ciro_pipeline.py).
ANTIGRAVITY_PROJECT_ID=

# ── Service Wiring ───────────────────────────────────────────────────────────
# Base URL the ADK pipeline tools use to call back into the FastAPI backend.
BACKEND_URL=http://localhost:8000
