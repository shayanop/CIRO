# CIRO — copy to backend/.env and fill in values for your environment

# Groq LLM (Reasoning Agent) — optional; fallback cache used when unset
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TIMEOUT_SECONDS=5

# Google Gemini / Antigravity (ADK agents in backend/agents/)
GEMINI_API_KEY=
GOOGLE_CLOUD_PROJECT=
ANTIGRAVITY_PROJECT_ID=

# Maps (static map URL only; overlays are file-backed)
GOOGLE_MAPS_API_KEY=

# ADK pipeline tools call this FastAPI base URL
BACKEND_URL=http://localhost:8000
